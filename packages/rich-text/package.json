{
  "name": "@cosmicjs/rich-text",
  "version": "0.1.0",
  "description": "Official React renderer for Cosmic rich-text (markdown + shortcode blocks and inline object embeds).",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react",
    "dev": "tsup src/index.ts --format cjs,esm --dts --external react --watch",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cosmic",
    "cms",
    "rich-text",
    "shortcodes",
    "react"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cosmicjs/cosmic-sdk-js.git",
    "directory": "packages/rich-text"
  },
  "homepage": "https://www.cosmicjs.com/docs/api/rich-text",
  "peerDependencies": {
    "react": ">=17"
  },
  "dependencies": {
    "marked": "^14.1.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
